{
    "name": "INIADPLUS",
    "short_name": "INIADPLUS",
    "version": "1.3.3",
    "manifest_version": 3,
    "description": "INIAD MOOCs \u306e\u8b1b\u7fa9\u30b9\u30e9\u30a4\u30c9\u3092 PDF \u3068\u3057\u3066\u4fdd\u5b58\u3057\u3084\u3059\u304f\u3059\u308b\u62e1\u5f35\u6a5f\u80fd",
    "homepage_url": "https://github.com/Kensuke-sam/iniad_plus",
    "permissions": [
        "debugger",
        "downloads",
        "storage"
    ],
    "background": {
        "service_worker": "js/service-worker.js"
    },
    "icons": {
        "16": "img/iniadpp16.png",
        "48": "img/iniadpp48.png",
        "128": "img/iniadpp128.png"
    },
    "content_scripts": [
        {
            "matches": [
                "https://moocs.iniad.org/*",
                "https://www.ace.toyo.ac.jp/ct/home*"
            ],
            "js": [
                "lib/jquery-3.6.0.min.js",
                "lib/jquery-1.12.0.ui.min.js",
                "lib/rgbcolor.js",
                "js/download-button.js",
                "js/colorchange.js",
                "js/backgroundchange.js",
                "js/background.js",
                "js/ace_json.js",
                "js/ace_json_button.js",
                "js/json_upload.js",
                "js/json_timetable_localstorage.js",
                "js/json_timetable.js",
                "js/tools.js",
                "js/moocsmemo_btn.js",
                "js/scrolltop.js",
                "js/drive_buttons.js",
                "js/class_sort_button.js",
                "js/class_sort_default.js",
                "js/class_sort.js",
                "js/class_sort_reflect.js",
                "js/textarea_count.js",
                "js/header.js",
                "js/memolist.js",
                "js/slideoperate.js",
                "js/slide_question.js",
                "js/memonulldelete.js"
            ],
            "css": [
                "lib/jquery-1.12.1.ui.css",
                "css/download-button.css",
                "css/ace_dl.css",
                "css/json_upload.css",
                "css/mymemo.css",
                "css/scrolltop.css",
                "css/class_sort.css",
                "css/settingform.css",
                "css/slideoperate.css",
                "css/pointer.css",
                "css/dragover.css",
                "css/theme01.css"
            ]
        },
        {
            "matches": [
                "https://docs.google.com/presentation/d/e/*"
            ],
            "js": [
                "lib/jquery-3.6.0.min.js",
                "js/download.js"
            ]
        }
    ]
}
